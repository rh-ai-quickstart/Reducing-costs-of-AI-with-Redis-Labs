    "def submit_feedback(question: str, answer: str, thumbs_up: bool, metadata: dict | None = None):\n",
    "    if not thumbs_up:\n",
    "        return \"not cached\"\n",
    "    cache.store(prompt=question, response=answer, metadata=metadata or {\"source\": \"agent\", \"approved\": True})\n",
    "    return \"cached\""
   ]
