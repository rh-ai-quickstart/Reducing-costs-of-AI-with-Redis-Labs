    "## 6. Wire the end-to-end pipeline\n",
    "\n",
    "`handle(question)` runs the full router \u2192 cache \u2192 agent flow and returns a dict describing what happened so we can inspect cost attribution on every call. Each result also carries a `usage` entry with `input_tokens` / `output_tokens` / `total_tokens` so the summary at the end of the notebook can compare token spend per route."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "pipeline",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-04-24T17:35:08.851593Z",
     "iopub.status.busy": "2026-04-24T17:35:08.851496Z",
     "iopub.status.idle": "2026-04-24T17:35:08.856181Z",
     "shell.execute_reply": "2026-04-24T17:35:08.855940Z"
    }
   },
   "outputs": [],
   "source": [
    "REFUSAL = (\n",
    "    \"I can't help with that. I'm limited to insurance account and claims questions.\"\n",
    ")\n",
    "\n",
    "# Per-route running totals for the final summary.\n",
    "USAGE_TOTALS = {\n",
    "    \"simple\":  {\"calls\": 0, \"input_tokens\": 0, \"output_tokens\": 0, \"total_tokens\": 0},\n",
    "    \"complex\": {\"calls\": 0, \"input_tokens\": 0, \"output_tokens\": 0, \"total_tokens\": 0},\n",
    "    \"cached\":  {\"calls\": 0, \"input_tokens\": 0, \"output_tokens\": 0, \"total_tokens\": 0},\n",
    "    \"blocked\": {\"calls\": 0, \"input_tokens\": 0, \"output_tokens\": 0, \"total_tokens\": 0},\n",
    "}\n",
    "\n",
    "def _agent_usage(result) -> dict:\n",
    "    \"\"\"Sum usage_metadata across every AIMessage in a LangGraph agent response.\"\"\"\n",
    "    totals = {\"input_tokens\": 0, \"output_tokens\": 0, \"total_tokens\": 0}\n",
    "    for msg in result.get(\"messages\", []):\n",
    "        um = getattr(msg, \"usage_metadata\", None) or {}\n",
    "        for k in totals:\n",
    "            totals[k] += int(um.get(k, 0) or 0)\n",
    "    return totals\n",
    "\n",
    "def _record(bucket: str, usage: dict) -> dict:\n",
    "    USAGE_TOTALS[bucket][\"calls\"] += 1\n",
    "    for k in (\"input_tokens\", \"output_tokens\", \"total_tokens\"):\n",
    "        USAGE_TOTALS[bucket][k] += int(usage.get(k, 0) or 0)\n",
    "    return usage\n",
    "\n",
    "def handle(question: str, thread_id: str = \"demo\") -> dict:\n",
    "    match = router(question)\n",
    "    route = match.name if match else None\n",
    "\n",
    "    if route == \"blocked\":\n",
    "        _record(\"blocked\", {})\n",
    "        return {\"route\": \"blocked\", \"model\": None, \"cached\": False,\n",
    "                \"answer\": REFUSAL, \"usage\": {}}\n",
    "\n",
    "    if route == \"simple-insurance\":\n",
    "        answer, usage = answer_simple(question)\n",
    "        _record(\"simple\", usage)\n",
    "        return {\"route\": \"simple\", \"model\": SIMPLE_MODEL, \"cached\": False,\n",
    "                \"answer\": answer, \"usage\": usage}\n",
    "\n",
    "    # complex path (or no-match falls through to complex/agent as the safe default)\n",
    "    hit = cache.check(prompt=question, num_results=1)\n",
    "    if hit:\n",
    "        _record(\"cached\", {})\n",
    "        return {\"route\": \"complex\", \"model\": None, \"cached\": True,\n",
    "                \"answer\": ib.strip_reasoning(hit[0][\"response\"]), \"usage\": {},\n",
    "                \"similarity_distance\": hit[0].get(\"vector_distance\")}\n",
    "\n",
    "    result = agent.invoke(\n",
    "        {\"messages\": [{\"role\": \"user\", \"content\": question}]},\n",
    "        config={\"configurable\": {\"thread_id\": thread_id}},\n",
    "    )\n",
    "    usage = _agent_usage(result)\n",
    "    _record(\"complex\", usage)\n",
    "    return {\"route\": \"complex\", \"model\": COMPLEX_MODEL, \"cached\": False,\n",
    "            \"answer\": ib.strip_reasoning(result[\"messages\"][-1].content), \"usage\": usage}"
   ]
  },
